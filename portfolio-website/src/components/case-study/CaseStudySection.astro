---
const { title } = Astro.props;
---

<section class="case-section">
  <h2>{title}</h2>

  <div class="content">
    <slot />
  </div>
</section>

<style>
  .case-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
  }

  h2 {
    margin: 0 0 1.25rem;
    font-size: clamp(1.6rem, 3vw, 2.3rem);
    letter-spacing: -0.04em;
  }

  .content {
    color: var(--text-muted);
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .content :global(p) {
    margin: 0 0 1rem;
  }

  .content :global(ul) {
    margin: 0;
    padding-left: 1.2rem;
  }

  .content :global(li) {
    margin-bottom: 0.65rem;
  }

  .content :global(li::marker) {
    color: var(--primary);
  }

  .content :global(strong) {
    color: var(--text-main);
  }
</style>