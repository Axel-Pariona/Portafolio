---
import SectionTitle from "../ui/SectionTitle.astro";
import ProjectCard from "../ui/ProjectCard.astro";
import { projects } from "../../data/projects";
---

<section id="proyectos" class="projects-section">
  <div class="container">
    <SectionTitle
      eyebrow="Proyectos"
      title="Aplicaciones que he construido para practicar, resolver problemas y mejorar como desarrollador."
      description="Estos proyectos reflejan mi avance trabajando con frontend, bases de datos, autenticación, seguridad, integraciones externas y despliegue en producción."
    />

    <div class="projects-grid">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .projects-grid :global(.project-card:first-child) {
    grid-column: span 2;
  }

  @media (max-width: 820px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .projects-grid :global(.project-card:first-child) {
      grid-column: span 1;
    }
  }
</style>