---
import SectionTitle from "../ui/SectionTitle.astro";
import SkillBadge from "../ui/SkillBadge.astro";
import { skillGroups } from "../../data/skills";
---

<section id="tecnologias" class="skills-section">
  <div class="container">
    <SectionTitle
      eyebrow="Tecnologías"
      title="Herramientas que uso para construir aplicaciones web funcionales."
      description="Mi stack principal está orientado al desarrollo web moderno, combinando frontend, bases de datos, autenticación, servicios serverless, integraciones externas y despliegue en producción."
    />

    <div class="skills-grid">
      {
        skillGroups.map((group) => (
          <article class="skill-card">
            <div>
              <h3>{group.title}</h3>
              <p>{group.description}</p>
            </div>

            <div class="badges">
              {group.skills.map((skill) => (
                <SkillBadge name={skill} />
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skills-section {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .skill-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 220px;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.015)
      );
  }

  .skill-card h3 {
    margin: 0;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
  }

  .skill-card p {
    margin: 0.75rem 0 0;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  @media (max-width: 820px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }

    .skill-card {
      min-height: auto;
    }
  }
</style>