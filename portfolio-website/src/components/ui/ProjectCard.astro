---
const { project } = Astro.props;
---

<article class="project-card">
  <div class="project-header">
    <div>
      <p class="project-type">{project.type}</p>
      <h3>{project.title}</h3>
    </div>

    <span class="status">{project.status}</span>
  </div>

  <p class="description">
    {project.description}
  </p>

  <div class="stack">
    {project.stack.map((tech) => (
      <span>{tech}</span>
    ))}
  </div>

  <ul class="highlights">
    {project.highlights.map((item) => (
      <li>{item}</li>
    ))}
  </ul>

  <div class="actions">
    <a href={`/proyectos/${project.slug}`} class="details-link">
      Ver caso de estudio
    </a>

    <div class="external-links">
      {project.demoUrl && (
        <a href={project.demoUrl} target="_blank" rel="noreferrer">
          Demo
        </a>
      )}

      {project.repoUrl && (
        <a href={project.repoUrl} target="_blank" rel="noreferrer">
          GitHub
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.045),
        rgba(255, 255, 255, 0.015)
      );
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(56, 189, 248, 0.5);
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }

  .project-type {
    margin: 0 0 0.5rem;
    color: var(--primary);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  h3 {
    margin: 0;
    font-size: 1.6rem;
    letter-spacing: -0.04em;
  }

  .status {
    flex-shrink: 0;
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 0.78rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .description {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .stack span {
    padding: 0.4rem 0.65rem;
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.08);
    color: var(--primary);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .highlights {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-muted);
  }

  .highlights li::marker {
    color: var(--primary);
  }

  .actions {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .details-link {
    color: var(--text-main);
    font-weight: 700;
  }

  .details-link:hover {
    color: var(--primary);
  }

  .external-links {
    display: flex;
    gap: 0.85rem;
  }

  .external-links a {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .external-links a:hover {
    color: var(--primary);
  }

  @media (max-width: 720px) {
    .project-header,
    .actions {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>