---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
---

<Layout
  title="Página no encontrada | Axel Pariona"
  description="La página que estás buscando no existe o fue movida."
>
  <Header />

  <main class="error-page">
    <div class="container error-content">
      <p class="eyebrow">Error 404</p>

      <h1>Página no encontrada</h1>

      <p class="description">
        Parece que la ruta que intentaste abrir no existe o fue movida.
        Puedes volver al inicio para seguir explorando mi portfolio.
      </p>

      <div class="actions">
        <a href="/" class="btn primary">Volver al inicio</a>
        <a href="/#proyectos" class="btn secondary">Ver proyectos</a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .error-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding: 5rem 0;
  }

  .error-content {
    max-width: 820px;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: var(--primary);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.85rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1;
    letter-spacing: -0.07em;
  }

  .description {
    max-width: 680px;
    margin: 1.5rem 0 0;
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 1.2rem;
    border-radius: 999px;
    font-weight: 700;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .primary {
    background: var(--primary);
    color: #020617;
  }

  .secondary {
    border: 1px solid var(--border);
    color: var(--text-main);
    background: rgba(255, 255, 255, 0.03);
  }

  .secondary:hover {
    border-color: var(--primary);
  }
</style>